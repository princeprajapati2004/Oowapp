// QR Ordering & Billing System — Prisma schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum BusinessType {
  RESTAURANT
  CAFE
  BAKERY
  GROCERY
  MEDICAL
  ELECTRONICS
  CLOTHING
  STORE
  OTHER
}

enum FoodType {
  VEG
  NON_VEG
  NA
}

enum TaxType {
  PERCENTAGE
  FIXED
}

enum TaxAppliesTo {
  ENTIRE_BILL
  CATEGORY
}

enum ShopStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
  DELETED
}

enum SubscriptionPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum AuditAction {
  // Auth
  ADMIN_SIGNUP
  ADMIN_LOGIN
  ADMIN_LOGOUT
  SUPER_ADMIN_LOGIN
  SUPER_ADMIN_LOGOUT
  // Business lifecycle
  SHOP_UPDATED
  SHOP_SUSPENDED
  SHOP_ACTIVATED
  SHOP_DELETED
  // Content
  CATEGORY_CREATED
  CATEGORY_UPDATED
  CATEGORY_DELETED
  PRODUCT_CREATED
  PRODUCT_UPDATED
  PRODUCT_DELETED
  TAX_CREATED
  TAX_UPDATED
  TAX_DELETED
  // Orders
  ORDER_CREATED
  // Platform
  PLATFORM_SETTINGS_UPDATED
  SUBSCRIPTION_CHANGED
}

// ─── Core Models ──────────────────────────────────────────────────────────────

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  shop         Shop?

  @@map("admins")
}

model Shop {
  id             String       @id @default(cuid())
  adminId        String       @unique
  admin          Admin        @relation(fields: [adminId], references: [id], onDelete: Cascade)
  slug           String       @unique
  businessName   String
  businessType   BusinessType @default(RESTAURANT)
  logoUrl        String?
  phone          String?
  whatsappNumber String
  address        String?
  gstNumber      String?
  currency       String       @default("INR")

  // Owner profile
  ownerName String?
  city      String?
  state     String?
  country   String?

  // Platform lifecycle
  status          ShopStatus @default(ACTIVE)
  lastLoginAt     DateTime?
  suspendedAt     DateTime?
  suspendedReason String?
  deletedAt       DateTime?

  // Payment settings
  upiId             String?
  acceptCash        Boolean @default(true)
  bankAccountName   String?
  bankAccountNumber String?
  bankIfsc          String?
  bankName          String?
  paymentQrImageUrl String?

  // Order settings
  requireCustomerName    Boolean @default(true)
  requirePhone           Boolean @default(false)
  requireTableNumber     Boolean @default(true)
  requireDeliveryAddress Boolean @default(false)
  allowNotes             Boolean @default(true)
  saveOrdersToDb         Boolean @default(false)

  isPublished Boolean  @default(true)

  // Restaurant-specific settings
  enableTableQr Boolean @default(false)
  tableNames    String? // JSON-encoded string[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories    Category[]
  products      Product[]
  taxes         Tax[]
  orders        Order[]
  subscriptions Subscription[]

  @@map("shops")
}

model Category {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int      @default(0)
  isVisible Boolean  @default(true)
  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
  taxes    Tax[]

  @@index([shopId])
  @@map("categories")
}

model Product {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  imageUrl    String?
  unit        String?
  foodType    FoodType @default(NA)
  isAvailable Boolean  @default(true)
  isVisible   Boolean  @default(true)
  stock       Int?
  sortOrder   Int      @default(0)
  createdBy   String?
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems OrderItem[]

  @@index([shopId])
  @@index([categoryId])
  @@map("products")
}

model Tax {
  id         String       @id @default(cuid())
  shopId     String
  shop       Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name       String
  type       TaxType      @default(PERCENTAGE)
  value      Decimal      @db.Decimal(10, 2)
  appliesTo  TaxAppliesTo @default(ENTIRE_BILL)
  categoryId String?
  category   Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  isEnabled  Boolean      @default(true)
  sortOrder  Int          @default(0)
  createdBy  String?
  updatedBy  String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([shopId])
  @@map("taxes")
}

model Order {
  id              String   @id @default(cuid())
  shopId          String
  shop            Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  billNumber      String
  customerName    String?
  customerPhone   String?
  tableNumber     String?
  deliveryAddress String?
  notes           String?
  subtotal        Decimal     @db.Decimal(10, 2)
  taxTotal        Decimal     @db.Decimal(10, 2)
  grandTotal      Decimal     @db.Decimal(10, 2)
  taxBreakdown    Json
  status          OrderStatus @default(PENDING)
  createdAt       DateTime    @default(now())

  items OrderItem[]

  @@index([shopId])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  name      String
  price     Decimal  @db.Decimal(10, 2)
  quantity  Int
  lineTotal Decimal  @db.Decimal(10, 2)

  @@index([orderId])
  @@map("order_items")
}

// ─── SaaS Platform Models ─────────────────────────────────────────────────────

model SuperAdmin {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("super_admins")
}

model Subscription {
  id        String             @id @default(cuid())
  shopId    String
  shop      Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  plan      SubscriptionPlan   @default(FREE)
  status    SubscriptionStatus @default(TRIAL)
  startDate DateTime           @default(now())
  endDate   DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([shopId])
  @@map("subscriptions")
}

model AuditLog {
  id         String      @id @default(cuid())
  action     AuditAction
  actorType  String
  actorId    String
  targetType String?
  targetId   String?
  metadata   Json?
  shopId     String?
  ipAddress  String?
  userAgent  String?
  requestId  String?
  createdAt  DateTime    @default(now())

  @@index([shopId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_logs")
}

model PlatformSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}
