// QR Ordering & Billing System — Prisma schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum BusinessType {
  RESTAURANT
  CAFE
  BAKERY
  GROCERY
  MEDICAL
  ELECTRONICS
  CLOTHING
  STORE
  OTHER
}

enum FoodType {
  VEG
  NON_VEG
  NA
}

enum TaxType {
  PERCENTAGE
  FIXED
}

enum TaxAppliesTo {
  ENTIRE_BILL
  CATEGORY
}

enum ShopStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
  DELETED
}

enum SubscriptionPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  SUSPENDED
  CANCELLED
}

enum SubscriptionDuration {
  FIFTEEN_DAYS
  ONE_MONTH
  THREE_MONTHS
  SIX_MONTHS
  TWELVE_MONTHS
  CUSTOM
}

enum SubscriptionActionType {
  CREATED
  RENEWED
  EXTENDED
  PLAN_CHANGED
  SUSPENDED
  RESUMED
  EXPIRED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum AuditAction {
  // Auth
  ADMIN_SIGNUP
  ADMIN_LOGIN
  ADMIN_LOGOUT
  SUPER_ADMIN_LOGIN
  SUPER_ADMIN_LOGOUT
  // Business lifecycle
  SHOP_UPDATED
  SHOP_SUSPENDED
  SHOP_ACTIVATED
  SHOP_DELETED
  // Content
  CATEGORY_CREATED
  CATEGORY_UPDATED
  CATEGORY_DELETED
  PRODUCT_CREATED
  PRODUCT_UPDATED
  PRODUCT_DELETED
  TAX_CREATED
  TAX_UPDATED
  TAX_DELETED
  // Orders
  ORDER_CREATED
  // Platform
  PLATFORM_SETTINGS_UPDATED
  SUBSCRIPTION_CHANGED
}

// ─── Core Models ──────────────────────────────────────────────────────────────

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  shop         Shop?

  @@map("admins")
}

model Shop {
  id             String       @id @default(cuid())
  adminId        String       @unique
  admin          Admin        @relation(fields: [adminId], references: [id], onDelete: Cascade)
  slug           String       @unique
  businessName   String
  businessType   BusinessType @default(RESTAURANT)
  logoUrl        String?
  phone          String?
  whatsappNumber String
  address        String?
  gstNumber      String?
  currency       String       @default("INR")

  // Owner profile
  ownerName String?
  city      String?
  state     String?
  country   String?

  // Platform lifecycle
  status          ShopStatus @default(ACTIVE)
  lastLoginAt     DateTime?
  suspendedAt     DateTime?
  suspendedReason String?
  deletedAt       DateTime?

  // Payment settings
  upiId             String?
  acceptCash        Boolean @default(true)
  bankAccountName   String?
  bankAccountNumber String?
  bankIfsc          String?
  bankName          String?
  paymentQrImageUrl String?

  // Order settings
  requireCustomerName    Boolean @default(true)
  requirePhone           Boolean @default(false)
  enableTableNumber      Boolean @default(true)
  requireTableNumber     Boolean @default(true)
  requireDeliveryAddress Boolean @default(false)
  allowNotes             Boolean @default(true)
  saveOrdersToDb         Boolean @default(false)

  isPublished Boolean  @default(true)

  // Restaurant-specific settings
  enableTableQr Boolean @default(false)
  tableNames    String? // JSON-encoded string[]

  // Push notification preferences
  notifyNewOrders    Boolean @default(true)
  notifyOrderUpdates Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories         Category[]
  products           Product[]
  taxes              Tax[]
  orders             Order[]
  subscriptions      Subscription[]
  pushSubscriptions  PushSubscription[]
  featurePermissions BusinessFeaturePermission[]

  @@map("shops")
}

model Category {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int      @default(0)
  isVisible Boolean  @default(true)
  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
  taxes    Tax[]

  @@index([shopId])
  @@map("categories")
}

model Product {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  imageUrl    String?
  unit        String?
  foodType    FoodType @default(NA)
  isAvailable Boolean  @default(true)
  isVisible   Boolean  @default(true)
  stock       Int?
  sortOrder   Int      @default(0)
  createdBy   String?
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems OrderItem[]

  @@index([shopId])
  @@index([categoryId])
  @@map("products")
}

model Tax {
  id         String       @id @default(cuid())
  shopId     String
  shop       Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name       String
  type       TaxType      @default(PERCENTAGE)
  value      Decimal      @db.Decimal(10, 2)
  appliesTo  TaxAppliesTo @default(ENTIRE_BILL)
  categoryId String?
  category   Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  isEnabled  Boolean      @default(true)
  sortOrder  Int          @default(0)
  createdBy  String?
  updatedBy  String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([shopId])
  @@map("taxes")
}

model Order {
  id              String   @id @default(cuid())
  shopId          String
  shop            Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  billNumber      String
  customerName    String?
  customerPhone   String?
  tableNumber     String?
  deliveryAddress String?
  notes           String?
  subtotal        Decimal     @db.Decimal(10, 2)
  taxTotal        Decimal     @db.Decimal(10, 2)
  grandTotal      Decimal     @db.Decimal(10, 2)
  taxBreakdown    Json
  status          OrderStatus @default(PENDING)
  paymentMethod   String?
  source          String      @default("qr")
  // Discount (Feature 3)
  discountType    String?
  discountValue   Decimal?    @db.Decimal(10, 2)
  discountReason  String?
  discountedTotal Decimal?    @db.Decimal(10, 2)
  createdAt       DateTime    @default(now())

  items OrderItem[]

  @@index([shopId])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  name      String
  price     Decimal  @db.Decimal(10, 2)
  quantity  Int
  lineTotal Decimal  @db.Decimal(10, 2)

  @@index([orderId])
  @@map("order_items")
}

// ─── SaaS Platform Models ─────────────────────────────────────────────────────

model SuperAdmin {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("super_admins")
}

model Subscription {
  id        String                 @id @default(cuid())
  shopId    String
  shop      Shop                   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  plan      SubscriptionPlan       @default(FREE)
  planId    String?
  planRef   Plan?                  @relation(fields: [planId], references: [id], onDelete: SetNull)
  status    SubscriptionStatus     @default(TRIAL)
  duration  SubscriptionDuration   @default(ONE_MONTH)
  action    SubscriptionActionType @default(CREATED)
  startDate DateTime               @default(now())
  endDate   DateTime?
  // Super admin actor id ("system" for auto-created trial subscriptions); nullable for
  // rows created before this column existed.
  createdBy String?
  remarks   String?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  @@index([shopId])
  @@index([shopId, createdAt])
  @@map("subscriptions")
}

// ─── Subscription Plans & Feature Permissions ─────────────────────────────────

model Plan {
  id          String   @id @default(cuid())
  // Matches the legacy SubscriptionPlan enum value during the migration bridge period
  // (see SUBSCRIPTION_POS_ARCHITECTURE.md, Decision A); free-form for plans created later.
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  planFeatures  PlanFeature[]
  subscriptions Subscription[]

  @@map("plans")
}

model Feature {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  description String?
  category    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  planFeatures      PlanFeature[]
  businessOverrides BusinessFeaturePermission[]

  @@map("features")
}

model PlanFeature {
  id        String  @id @default(cuid())
  planId    String
  plan      Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  featureId String
  feature   Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)
  enabled   Boolean @default(true)

  @@unique([planId, featureId])
  @@map("plan_features")
}

// Per-business override layer resolved on top of the plan's defaults — see
// src/lib/services/feature-permission.ts::resolveFeatures for resolution order.
model BusinessFeaturePermission {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  featureId String
  feature   Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)
  enabled   Boolean
  reason    String?
  updatedBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shopId, featureId])
  @@index([shopId])
  @@map("business_feature_permissions")
}

model AuditLog {
  id         String      @id @default(cuid())
  action     AuditAction
  actorType  String
  actorId    String
  targetType String?
  targetId   String?
  metadata   Json?
  shopId     String?
  ipAddress  String?
  userAgent  String?
  requestId  String?
  createdAt  DateTime    @default(now())

  @@index([shopId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_logs")
}

model PlatformSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}

// Feature 4: Web push subscriptions
model PushSubscription {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
  @@map("push_subscriptions")
}
