# PostgreSQL connection string (Neon, Supabase, Railway, or local)
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Random secret used to sign admin session JWTs — generate with `openssl rand -base64 32`
JWT_SECRET="replace-with-a-long-random-secret"

# Vercel Blob storage token — Vercel dashboard -> Storage -> Blob -> create token
BLOB_READ_WRITE_TOKEN=""

# Public base URL of the deployed app, used to build QR codes / order links
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

